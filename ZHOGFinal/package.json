{
  "name": "dead-zone-escape",
  "version": "1.0.0",
  "description": "Dead Zone: Escape - A zombie survival hidden object game",
  "main": "game.js",
  "scripts": {
    "start": "npx http-server . -p 5500 -o",
    "android:init": "npx cap add android",
    "android:sync": "npx cap sync android",
    "android:open": "npx cap open android",
    "android:run": "npx cap run android",
    "android:build": "npx cap sync android && cd android && ./gradlew assembleRelease"
  },
  "keywords": [
    "game",
    "hidden-object",
    "zombie",
    "survival",
    "android"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "eslint": "^10.0.3",
    "http-server": "^14.1.1"
  },
  "dependencies": {
    "@capacitor-community/admob": "^6.0.0",
    "@capacitor/android": "^6.0.0",
    "@capacitor/core": "^6.0.0"
  }
}
